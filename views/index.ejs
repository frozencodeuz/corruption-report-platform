<%- include('layout', { title, body: ` <div class="public-page">

  <header class="gov-header">
    <div class="container gov-header-inner">
      <a href="/" class="gov-brand" aria-label="Асосий саҳифа">
        <span class="gov-emblem" aria-hidden="true">
          <svg viewBox="0 0 32 32">
            <path d="M16 2.8 27 7.6v8.2c0 6.8-4.55 12.5-11 13.9C9.55 28.3 5 22.6 5 15.8V7.6l11-4.8Z" fill="none"
              stroke="currentColor" stroke-width="2.1" />
            <path d="M16 9.4v8.1" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
            <path d="M16 22.2h.01" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" />
          </svg>
        </span>
        <span>
          <strong>Коррупцион ҳолатлар бўйича хабар бериш</strong>
          <small>Расмий, хавфсиз ва аноним веб-қабулхона</small>
        </span>
      </a>
      </a>
    </div>
  </header>

  <main>
    <section class="hero-gov">
      <div class="container hero-grid">
        <div class="hero-content">
          <div class="badge-line"><span></span> Анонимлик · Хавфсиз қабул · Масъул назорат</div>
          <h1>Коррупцион ҳолат ҳақида аниқ ва хавфсиз хабар беринг</h1>
          <p class="hero-text">Пора, таъмагирлик, мансаб ваколатини суиистеъмол қилиш, сунъий тўсиқ ёки манфаатлар
            тўқнашуви ҳақида маълумот юборинг. Хабар берувчининг шахси сир сақланади.</p>

          <div class="hero-note"><b>Муҳим:</b> Ф.И.Ш, паспорт ва яшаш манзили сўралмайди. Фақат алоқа учун телефон рақам
            мажбурий.</div>
        </div>

        <div class="mobile-form-intro">
          <span class="mfi-icon">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2.1">
              <path d="M16 2.8 27 7.6v8.2c0 6.8-4.55 12.5-11 13.9C9.55 28.3 5 22.6 5 15.8V7.6l11-4.8Z" />
              <path d="M16 9.4v8.1" stroke-width="2.4" stroke-linecap="round" />
              <path d="M16 22.2h.01" stroke-width="3.4" stroke-linecap="round" />
            </svg>
          </span>
          <span class="mfi-text">
            <strong>Коррупцион ҳолат ҳақида хабар</strong>
            <small>Аноним · Хавфсиз · Расмий қабул</small>
          </span>
          <span class="mfi-badge">🔒 Аноним</span>
        </div>

        <form class="report-form hero-form" action="/submit" method="post" enctype="multipart/form-data" novalidate>
          <div class="form-header">
            <div>
              <h2>Хабар маълумотлари</h2>
              <p>Юлдузча (*) билан белгиланган майдонлар мажбурий.</p>
            </div>
            <span>Аноним</span>
          </div>

          ${error ? `<div class="alert error">${h(error)}</div>` : ''}

          <div class="form-grid-two">
            <label>
              <span>Телефон рақам *</span>
              <input name="phone" type="tel" required inputmode="tel" placeholder="+998 90 123 45 67"
                value="${h(old.phone || '')}">
            </label>
            <label>
              <span>Ҳолат тури *</span>
              <select name="incident_type" required>
                ${Object.entries(INCIDENT_TYPES).map(([key, label]) => `<option value="${key}" ${old.incident_type===key
                  ? 'selected' : '' }>${h(label)}</option>`).join('')}
              </select>
            </label>
            <label>
              <span>Ҳолат содир бўлган сана</span>
              <input name="event_date" type="date" value="${h(old.event_date || '')}">
            </label>
            <label>
              <span>Ҳолат содир бўлган жой *</span>
              <input name="place" type="text" required placeholder="Ташкилот, маҳалла ёки идора"
                value="${h(old.place || '')}">
            </label>
          </div>

          <label>
            <span>Ҳолат мазмуни *</span>
            <textarea name="message" required minlength="30" rows="2"
              placeholder="Ҳолат қаерда, қачон, кимлар иштирокида ва қандай содир бўлганини батафсил ёзинг.">${h(old.message || '')}</textarea>
          </label>

          <label class="file-dropzone" style="padding: 18px !important;">
            <input name="evidence" type="file" multiple accept="image/*,video/*,application/pdf">
            <div style="display:flex; align-items:center; justify-content:center; gap: 12px;">
              <span class="file-icon" style="margin:0; width:36px; height:36px; font-size:24px;">＋</span>
              <div style="text-align:left;">
                <b style="display:block;">Исбот файлларини илова қилиш</b>
                <small style="margin-top:2px;">JPG, PNG, PDF, MP4 · макс ${MAX_FILES} та</small>
              </div>
            </div>
          </label>

          <label class="check-row">
            <input name="consent" type="checkbox" required ${old.consent ? 'checked' : '' }>
            <span>Юборилаётган маълумотлар холис, текширилган ва ҳақиқатга мос эканини тасдиқлайман.</span>
          </label>

          <button class="btn btn-primary submit-btn" type="submit">Хабарни хавфсиз юбориш</button>
        </form>
      </div>
    </section>



    <section id="report" class="container report-wrap">
      <div class="report-side">
        <div class="section-title">
          <span>Онлайн форма</span>
          <h2>Коррупцион ҳолат бўйича аноним хабар</h2>
          <p>Ҳолатни аниқ, холис ва текширилган фактлар асосида ёзинг. Имкон қадар сана, жой, ташкилот ва воқеа
            тафсилотларини кўрсатинг.</p>
        </div>
        <div class="info-box">
          <b>Нима учун телефон рақам сўралади?</b>
          <p>Фақат ҳолатни аниқлаштириш зарурати туғилганда масъул ходим боғланиши учун. Ушбу маълумот очиқ эълон
            қилинмайди.</p>
        </div>
      </div>

      <aside class="hero-panel" aria-label="Платформа маълумоти">
        <div class="panel-head">
          <span class="panel-icon">🔒</span>
          <div><b>Аноним хабар режими</b><small>шахсий маълумотлар минимал</small></div>
        </div>
        <div class="panel-list">
          <div><span>01</span>
            <p>Ҳолат ҳақида қисқа ва аниқ маълумот киритилади</p>
          </div>
          <div><span>02</span>
            <p>Расм, видео ёки PDF файллар исбот сифатида илова қилинади</p>
          </div>
          <div><span>03</span>
            <p>Хабар махсус админ панелда статуслар орқали назорат қилинади</p>
          </div>
        </div>
        <div class="panel-metrics">
          <div><b>${MAX_FILES}</b><span>та файлгача</span></div>
          <div><b>${MAX_FILE_MB}</b><span>MB гача</span></div>
          <div><b>ID</b><span>рақам берилади</span></div>
        </div>
      </aside>
    </section>
  </main>

  <footer class="public-footer">
    <div class="container footer-inner">
      <span>Коррупцион ҳолатлар бўйича аноним хабар бериш платформаси</span>
      <div style="display:flex; gap:20px; align-items:center;">
        <span>© ${new Date().getFullYear()}</span>
        <a href="/admin" style="font-weight:900; color:var(--blue);">Тизимга кириш</a>
      </div>
    </div>
  </footer>
  </div>
  ` }) %>