<%- include('layout', { title, body: `
<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="sidebar-brand">
      <span class="sidebar-logo">⚑</span>
      <div><b>Назорат панели</b><small>Мониторинг тизими</small></div>
    </div>

    <div class="sidebar-section-label">Бош меню</div>
    <nav class="sidebar-nav">
      <a class="active" href="/admin">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="7" height="7" rx="1.5"/><rect x="11" y="3" width="7" height="7" rx="1.5"/><rect x="2" y="12" width="7" height="7" rx="1.5"/><rect x="11" y="12" width="7" height="7" rx="1.5"/></svg>
        Хабарлар реестри
      </a>
      <a href="/admin/export.csv?status=${encodeURIComponent(filters.status)}&q=${encodeURIComponent(filters.q)}&priority=${encodeURIComponent(filters.priority)}&from=${encodeURIComponent(filters.from)}&to=${encodeURIComponent(filters.to)}">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 16v1a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-1M7 10l3 3 3-3M10 13V3"/></svg>
        CSV Экспорт
      </a>
      <a href="/" target="_blank">
        <svg class="nav-icon" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="10" r="7"/><path d="M3.5 10h13M10 3.5a10 10 0 0 1 0 13M10 3.5a10 10 0 0 0 0 13"/></svg>
        Оммавий саҳифа
      </a>
    </nav>

    <div class="sidebar-user">
      <div class="sidebar-avatar">${h(adminUsername).charAt(0).toUpperCase()}</div>
      <div class="sidebar-user-info">
        <b>${h(adminUsername)}</b>
        <small>Администратор</small>
      </div>
    </div>

    <form action="/admin/logout" method="post" class="sidebar-bottom">
      <button type="submit">
        <svg style="width:16px;height:16px;flex-shrink:0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M13 10H3m10 0-3-3m3 3-3 3M8 5V3a1 1 0 0 1 1-1h7a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1v-2"/></svg>
        Тизимдан чиқиш
      </button>
    </form>
  </aside>

  <main class="admin-main">
    <header class="admin-top">
      <div>
        <span class="admin-kicker">Коррупцион ҳолатлар мониторинги</span>
        <h1>Келган хабарлар реестри</h1>
        <p>Хабарларни қидириш, фильтрлаш, кўриш, статусини ўзгартириш ва экспорт қилиш</p>
      </div>
      <a class="btn btn-primary" href="/admin/export.csv?status=${encodeURIComponent(filters.status)}&q=${encodeURIComponent(filters.q)}&priority=${encodeURIComponent(filters.priority)}&from=${encodeURIComponent(filters.from)}&to=${encodeURIComponent(filters.to)}">
        <svg style="width:16px;height:16px" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 16v1a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-1M7 10l3 3 3-3M10 13V3"/></svg>
        CSV Экспорт
      </a>
    </header>

    <section class="admin-stats">
      <a href="/admin" class="stat-card">
        <span>Жами хабарлар</span>
        <b>${counts.total || 0}</b>
        <small>барчаси</small>
      </a>
      <a href="/admin?status=new" class="stat-card stat-new">
        <span>Янги</span>
        <b>${counts.new || 0}</b>
        <small>кўриб чиқилмаган</small>
      </a>
      <a href="/admin?status=reviewing" class="stat-card stat-reviewing">
        <span>Ижрода</span>
        <b>${counts.reviewing || 0}</b>
        <small>ўрганилмоқда</small>
      </a>
      <a href="/admin?priority=urgent" class="stat-card stat-urgent">
        <span>Тезкор</span>
        <b>${counts.urgent || 0}</b>
        <small>юқори муҳимлик</small>
      </a>
      <a href="/admin?status=closed" class="stat-card stat-closed">
        <span>Якунланган</span>
        <b>${counts.closed || 0}</b>
        <small>ёпилган</small>
      </a>
    </section>

    <section class="filter-card">
      <div class="filter-card-header">
        <div class="filter-icon">⚙</div>
        <h3>Қидириш ва фильтрлаш</h3>
      </div>
      <form method="get" action="/admin" class="admin-filters">
        <label>
          <span>Қидириш</span>
          <input name="q" value="${h(filters.q)}" placeholder="ID, телефон, жой, матн...">
        </label>
        <label>
          <span>Статус</span>
          <select name="status">
            <option value="" ${!filters.status ? 'selected' : ''}>Барчаси</option>
            ${Object.entries(STATUSES).map(([key, meta]) => `<option value="${key}" ${filters.status === key ? 'selected' : ''}>${h(meta.label)}</option>`).join('')}
          </select>
        </label>
        <label>
          <span>Муҳимлик</span>
          <select name="priority">
            <option value="" ${!filters.priority ? 'selected' : ''}>Барчаси</option>
            ${Object.entries(PRIORITIES).map(([key, label]) => `<option value="${key}" ${filters.priority === key ? 'selected' : ''}>${h(label)}</option>`).join('')}
          </select>
        </label>
        <label>
          <span>Санадан</span>
          <input type="date" name="from" value="${h(filters.from)}">
        </label>
        <label>
          <span>Санагача</span>
          <input type="date" name="to" value="${h(filters.to)}">
        </label>
        <button type="submit" class="filter-submit">Фильтрлаш</button>
      </form>
    </section>

    <section class="registry-card">
      <div class="registry-head">
        <div>
          <h2>Хабарлар рўйхати</h2>
          <p>${reports.length} та натижа кўрсатилмоқда</p>
        </div>
      </div>
      <div class="table-scroll">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Хабар ID</th>
              <th>Сана / Вақт</th>
              <th>Телефон</th>
              <th>Ҳолат тури</th>
              <th>Содир бўлган жой</th>
              <th>Файл</th>
              <th>Муҳимлик</th>
              <th>Статус</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            ${reports.length ? reports.map(r => `
              <tr>
                <td><b class="mono" style="font-size:12px;color:var(--blue)">${h(r.id)}</b></td>
                <td><span class="muted-text">${h(r.created_at)}</span></td>
                <td><span style="font-weight:600">${h(r.phone_display)}</span></td>
                <td><span style="max-width:180px;display:inline-block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${h(r.incident_type_label)}</span></td>
                <td><span class="place-cell">${h(r.place)}</span></td>
                <td>
                  <span class="file-count" title="${r.file_count || 0} та файл">${r.file_count || 0}</span>
                </td>
                <td><span class="priority-pill ${h(r.priority || 'normal')}">${h(r.priority_label)}</span></td>
                <td><span class="status-pill ${h(r.status)}">${h(r.status_label)}</span></td>
                <td><a class="row-action" href="/admin/reports/${encodeURIComponent(r.id)}">Кўриш →</a></td>
              </tr>
            `).join('') : `
              <tr>
                <td colspan="9" class="empty-row">
                  <div style="display:flex;flex-direction:column;align-items:center;gap:10px">
                    <span style="font-size:36px">📭</span>
                    <span>Ҳозирча хабар йўқ</span>
                    <small style="color:var(--muted);font-size:12px">Фильтрни ўзгартириб кўринг</small>
                  </div>
                </td>
              </tr>
            `}
          </tbody>
        </table>
      </div>
    </section>
  </main>
</div>
` }) %>
