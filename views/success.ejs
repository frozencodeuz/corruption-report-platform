<%- include('layout', { title, body: `
<div class="success-page">
  <div class="success-card">
    <div class="success-mark">✓</div>
    <h1>Хабарингиз қабул қилинди</h1>
    <p>Коррупцион ҳолат бўйича хабарингиз масъуллар томонидан белгиланган тартибда кўриб чиқилади ва зарур чоралар кўрилади.</p>

    <div class="receipt-box">
      <span>Хабар рақами (сақлаб олинг)</span>
      <b>${h(report.id)}</b>
    </div>

    <div class="success-info">
      <div>
        <b>Статус</b>
        <span>${h(report.status_label)}</span>
      </div>
      <div>
        <b>Қабул вақти</b>
        <span>${h(report.created_at)}</span>
      </div>
      <div>
        <b>Ҳолат тури</b>
        <span>${h(report.incident_type_label)}</span>
      </div>
    </div>

    <div class="notice-blue">
      🔒 Шахсингиз сир сақланади. Зарур ҳолларда масъуллар телефон рақам орқали боғланиши мумкин.
    </div>

    <a class="btn btn-primary" href="/" style="width:100%;justify-content:center">
      ← Яна хабар юбориш
    </a>
  </div>
</div>
` }) %>
